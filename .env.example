# Database Configuration
# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/tharwah_capital

# Authentication
# Required: JWT secret for signing tokens (use: openssl rand -base64 32)
JWT_SECRET=your-secure-jwt-secret-here

# Supabase Configuration (if using Supabase for additional features)
# Optional: Supabase URL
SUPABASE_URL=https://your-project.supabase.co

# Required for server-side operations: Supabase Service Role Key
# WARNING: Keep this secret! Never expose to frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Anon Key (safe to expose to frontend)
SUPABASE_ANON_KEY=your-anon-key-here

# Frontend URL (for CORS configuration)
# Used in development and production
FRONTEND_URL=http://localhost:5173

# Environment
# Values: development, production
NODE_ENV=development

# Logging (optional)
# Values: debug, info, warn, error
LOG_LEVEL=info
