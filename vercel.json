{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    { "source": "/api/v1/health", "destination": "/api/v1/health" },
    { "source": "/api/v1/auth/admin-login", "destination": "/api/v1/auth/admin-login" },
    { "source": "/api/v1/auth/client-login","destination": "/api/v1/auth/client-login" },
    { "source": "/api/v1/clients",           "destination": "/api/v1/clients" },
    { "source": "/api/v1/transactions",      "destination": "/api/v1/transactions" },
    { "source": "/api/v1/portfolios",        "destination": "/api/v1/portfolios" },
    { "source": "/api/v1/settings",          "destination": "/api/v1/settings" },
    { "source": "/api/v1/messages",          "destination": "/api/v1/messages" },
    { "source": "/api/v1/sub-admins",        "destination": "/api/v1/sub-admins" },
    { "source": "/api/v1/notifications",     "destination": "/api/v1/notifications" },
    { "source": "/api/v1/overview",          "destination": "/api/v1/overview" },
    { "source": "/((?!api/).*)",             "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, PATCH, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
