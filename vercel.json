{
  "installCommand": "cd golden-horizon && bun install",
  "buildCommand": "cd golden-horizon && bun run build",
  "outputDirectory": "golden-horizon/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
